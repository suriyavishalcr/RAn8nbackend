    {
      "parameters": {
        "jsCode": "const now = new Date();\nconst istOffset = 5.5 * 60 * 60 * 1000;\nconst ist = new Date(now.getTime() + istOffset);\nconst today = ist.toISOString().split('T')[0];\n\nconst tasks = $input.all()\n  .map(i => i.json)\n  .filter(t => t.date === today);\n\nconst total = tasks.length;\nconst completed = tasks.filter(t => t.status === 'done').length;\nconst missed = tasks.filter(t => t.status === 'pending').length;\nconst score = total > 0 ? Math.round((completed / total) * 100) : 0;\n\nconst taskLines = tasks.map(t => {\n  const icon = t.status === 'done' ? '✅' : '❌';\n  return `${icon} ${t.task} (${t.startHour}:00 – ${t.endHour}:00)`;\n}).join('\\n');\n\nconst userEmail = tasks[0]?.uemail || '';\n\nreturn [{\n  json: { today, total, completed, missed, score, taskLines, userEmail }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
